{
	"name": "omnicode-vscode",
	"displayName": "Omnicode",
	"description": "VS Code integration for Omnicode - multi-provider local-first AI coding assistant",
	"version": "0.3.0",
	"publisher": "nanocollective",
	"repository": {
		"type": "git",
		"url": "https://github.com/Nano-Collective/nanocoder.git"
	},
	"engines": {
		"vscode": "^1.125.0"
	},
	"categories": [
		"Programming Languages",
		"Machine Learning",
		"Other"
	],
	"keywords": [
		"ai",
		"coding",
		"assistant",
		"omnicode",
		"nanocoder",
		"ollama",
		"deepseek",
		"local",
		"claude-code-alternative"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"icon": "media/icon.png",
	"contributes": {
		"commands": [
			{
				"command": "omnicode.connect",
				"title": "Connect to Omnicode",
				"category": "Omnicode"
			},
			{
				"command": "omnicode.disconnect",
				"title": "Disconnect from Omnicode",
				"category": "Omnicode"
			},
			{
				"command": "omnicode.startCli",
				"title": "Start Omnicode CLI",
				"category": "Omnicode"
			}
		],
		"configuration": {
			"title": "Omnicode",
			"properties": {
				"nanocoder.serverPort": {
					"type": "number",
					"default": 51820,
					"description": "WebSocket server port for communication with Omnicode CLI"
				},
				"nanocoder.autoConnect": {
					"type": "boolean",
					"default": true,
					"description": "Automatically connect to Omnicode CLI on startup"
				},
				"nanocoder.autoStartCli": {
					"type": "boolean",
					"default": false,
					"description": "Automatically start Omnicode CLI if not running"
				},
				"nanocoder.showDiffPreview": {
					"type": "boolean",
					"default": true,
					"description": "Show diff preview before applying file changes"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "pnpm run build",
		"build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
		"watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
		"lint": "eslint src --ext ts"
	},
	"devDependencies": {
		"@types/node": "^25.9.3",
		"@types/vscode": "^1.125.0",
		"@types/ws": "^8.5.10",
		"@vscode/vsce": "^3.9.1",
		"esbuild": "^0.28.1",
		"eslint": "^10.1.0",
		"typescript": "^5.3.0"
	},
	"dependencies": {
		"ws": "^8.16.0"
	}
}
